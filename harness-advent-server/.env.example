# Локальное состояние. Файл базы игнорируется Git.
HARNESS_DATABASE_URL=jdbc:sqlite:./harness-advent.db

# Разрешённые абсолютные пути рабочих копий через запятую. Оставь пустым, пока проекты не подключены.
HARNESS_ALLOWED_PROJECTS=

# Только URL и каталог моделей. Ключи и токены сюда не записываются.
HARNESS_LOCAL_MODEL_ENDPOINT=
HARNESS_LOCAL_MODELS=
HARNESS_DEEPSEEK_ENDPOINT=
HARNESS_DEEPSEEK_MODELS=
HARNESS_OPENROUTER_ENDPOINT=
HARNESS_OPENROUTER_MODELS=
